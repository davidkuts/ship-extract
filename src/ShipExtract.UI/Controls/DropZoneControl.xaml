<UserControl x:Class="ShipExtract.UI.Controls.DropZoneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True"
             Cursor="Hand">

    <Border x:Name="DropBorder"
            BorderBrush="{StaticResource PrimaryLightBrush}"
            BorderThickness="2"
            CornerRadius="12"
            Background="{StaticResource SurfaceBrush}"
            Padding="24">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryLightBrush}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsDragOver, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        <Setter Property="Background"  Value="#10C55A11"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <!-- Normal / drag-over content -->
            <StackPanel x:Name="NormalContent"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Vertical">

                <!-- Cloud upload icon (SVG path) -->
                <Viewbox Width="48" Height="48" Margin="0,0,0,12">
                    <Canvas Width="24" Height="24">
                        <Path Fill="{StaticResource PrimaryLightBrush}"
                              Data="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM14 13v4h-4v-4H7l5-5 5 5h-3z"/>
                    </Canvas>
                </Viewbox>

                <TextBlock x:Name="DropLabel"
                           Text="Drop PDF files here"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="or click to browse"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- File count badge — visible during drag when PDF files are present -->
            <Border x:Name="DragCountBadge"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="10"
                    Padding="8,3"
                    Margin="0,0,0,0"
                    Visibility="Collapsed">
                <TextBlock x:Name="DragCountText"
                           Text=""
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="White"/>
            </Border>

            <!-- Rejection feedback — visible briefly after dropping non-PDF files -->
            <Border x:Name="RejectionBanner"
                    VerticalAlignment="Bottom"
                    Background="#CC333333"
                    CornerRadius="6"
                    Padding="10,6"
                    Margin="0,0,0,0"
                    Visibility="Collapsed">
                <TextBlock x:Name="RejectionText"
                           Text=""
                           FontSize="12"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
