<Window x:Class="ShipExtract.UI.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About ShipExtract"
        Width="380" Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SurfaceBrush}">

    <StackPanel Margin="24" VerticalAlignment="Center">

        <!-- Logo -->
        <Viewbox Width="56" Height="56" HorizontalAlignment="Center" Margin="0,0,0,12">
            <Canvas Width="24" Height="24">
                <Path Fill="{StaticResource PrimaryBrush}"
                      Data="M20 21c-1.39 0-2.78-.47-4-1.32-2.44 1.71-5.56 1.71-8 0C6.78 20.53 5.39 21 4 21H2v2h2c1.38 0 2.74-.35 4-.99 2.52 1.29 5.48 1.29 8 0 1.26.64 2.62.99 4 .99h2v-2h-2zM3.95 19H4c1.6 0 3.02-.88 4-2 .98 1.12 2.4 2 4 2s3.02-.88 4-2c.98 1.12 2.4 2 4 2h.05l1.89-6.68c.08-.26.06-.54-.06-.78s-.34-.42-.6-.5L20 10.62V6c0-1.1-.9-2-2-2h-3V1H9v3H6c-1.1 0-2 .9-2 2v4.62l-1.29.42c-.26.08-.48.26-.6.5s-.14.52-.06.78L3.95 19zM6 6h12v3.97L12 8 6 9.97V6z"/>
            </Canvas>
        </Viewbox>

        <TextBlock Text="ShipExtract"
                   FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,4"/>

        <TextBlock x:Name="VersionText"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,16"/>

        <Separator Background="{StaticResource SurfaceDarkBrush}" Margin="0,0,0,12"/>

        <TextBlock Text="Powered by Claude AI (Anthropic)"
                   HorizontalAlignment="Center" FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
        <TextBlock Text="PDF parsing by PdfPig"
                   HorizontalAlignment="Center" FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
        <TextBlock Text="OCR by Tesseract"
                   HorizontalAlignment="Center" FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

        <Separator Background="{StaticResource SurfaceDarkBrush}" Margin="0,0,0,12"/>

        <TextBlock Text="&#x00A9; 2025 ShipExtract"
                   HorizontalAlignment="Center" FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

        <Button Content="Close"
                Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Center"
                Padding="24,8"
                Click="CloseButton_Click"/>
    </StackPanel>
</Window>
