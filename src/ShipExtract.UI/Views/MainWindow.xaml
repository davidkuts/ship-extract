<Window x:Class="ShipExtract.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ShipExtract.UI.Controls"
        xmlns:converters="clr-namespace:ShipExtract.UI.Converters"
        xmlns:views="clr-namespace:ShipExtract.UI.Views"
        xmlns:vm="clr-namespace:ShipExtract.UI.ViewModels"
        Title="{Binding WindowTitle, Mode=OneWay}"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">

    <Window.Resources>
        <converters:ProcessingStatusToColorConverter  x:Key="StatusToColor"/>
        <converters:ProcessingStatusToStringConverter x:Key="StatusToString"/>
        <converters:BoolToVisibilityConverter         x:Key="BoolToVisibility"/>
        <converters:NullToVisibilityConverter         x:Key="NullToVisibility"/>
        <converters:CarrierToBackgroundConverter      x:Key="CarrierToBackground"/>
        <converters:CarrierToForegroundConverter      x:Key="CarrierToForeground"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Warning banners -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="24"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════
             ROW 0 — Header
             ═══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>  <!-- History -->
                    <ColumnDefinition Width="Auto"/>  <!-- About -->
                    <ColumnDefinition Width="Auto"/>  <!-- Settings -->
                </Grid.ColumnDefinitions>

                <!-- App title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="28" Height="28" Margin="0,0,10,0">
                        <Canvas Width="24" Height="24">
                            <Path Fill="White"
                                  Data="M20 21c-1.39 0-2.78-.47-4-1.32-2.44 1.71-5.56 1.71-8 0C6.78 20.53 5.39 21 4 21H2v2h2c1.38 0 2.74-.35 4-.99 2.52 1.29 5.48 1.29 8 0 1.26.64 2.62.99 4 .99h2v-2h-2zM3.95 19H4c1.6 0 3.02-.88 4-2 .98 1.12 2.4 2 4 2s3.02-.88 4-2c.98 1.12 2.4 2 4 2h.05l1.89-6.68c.08-.26.06-.54-.06-.78s-.34-.42-.6-.5L20 10.62V6c0-1.1-.9-2-2-2h-3V1H9v3H6c-1.1 0-2 .9-2 2v4.62l-1.29.42c-.26.08-.48.26-.6.5s-.14.52-.06.78L3.95 19zM6 6h12v3.97L12 8 6 9.97V6z"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="ShipExtract"
                               FontSize="20" FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- History button -->
                <Button Grid.Column="1"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="8,6"
                        Click="HistoryButton_Click"
                        ToolTip="Batch History"
                        Margin="0,0,4,0">
                    <TextBlock Text="&#x1F4CB;" FontSize="14" Foreground="White"/>
                </Button>

                <!-- About button -->
                <Button Grid.Column="2"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="6"
                        Click="AboutButton_Click"
                        ToolTip="About"
                        Margin="0,0,4,0">
                    <TextBlock Text="&#x2139;" FontSize="16" Foreground="White"/>
                </Button>

                <!-- Settings button -->
                <Button Grid.Column="3"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="8"
                        Click="SettingsButton_Click"
                        ToolTip="Settings">
                    <Viewbox Width="20" Height="20">
                        <Canvas Width="24" Height="24">
                            <Path Fill="White"
                                  Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════
             ROW 1 — Warning banners
             ═══════════════════════════════════════ -->
        <StackPanel Grid.Row="1">
            <!-- API Key missing banner -->
            <Border Background="{StaticResource AccentBrush}"
                    Padding="10,8"
                    Visibility="{Binding ApiKeyIsSet, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                <Grid>
                    <TextBlock Text="&#x26A0; No Anthropic API key configured. AI extraction will fail."
                               Foreground="White" VerticalAlignment="Center" FontSize="13"/>
                    <Button Content="Open Settings"
                            HorizontalAlignment="Right"
                            Style="{StaticResource SecondaryButton}"
                            Background="White"
                            Foreground="{StaticResource AccentBrush}"
                            Padding="8,4"
                            Click="SettingsButton_Click"/>
                </Grid>
            </Border>

            <!-- OCR unavailable banner -->
            <Border Background="#7B5EA7"
                    Padding="10,8"
                    Visibility="{Binding OcrIsAvailable, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                <Grid>
                    <TextBlock Text="&#x2139; Tesseract not configured. Scanned PDFs will be skipped."
                               Foreground="White" VerticalAlignment="Center" FontSize="13"/>
                    <Button Content="Open Settings"
                            HorizontalAlignment="Right"
                            Style="{StaticResource SecondaryButton}"
                            Background="White"
                            Foreground="#7B5EA7"
                            Padding="8,4"
                            Click="SettingsButton_Click"/>
                </Grid>
            </Border>

            <!-- Ollama not running banner -->
            <Border Background="#7B6C00"
                    Padding="10,8"
                    Visibility="{Binding OllamaWarningVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <TextBlock Text="&#x26A0; Ollama is not running. Start it with: ollama serve"
                               Foreground="White" VerticalAlignment="Center" FontSize="13"/>
                    <Button Content="Check Again"
                            HorizontalAlignment="Right"
                            Style="{StaticResource SecondaryButton}"
                            Background="White"
                            Foreground="#7B6C00"
                            Padding="8,4"
                            Click="CheckOllamaButton_Click"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- ═══════════════════════════════════════
             ROW 2 — Main Content
             ═══════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT COLUMN ── -->
            <DockPanel Grid.Column="0" Background="White" Margin="0,0,1,0">

                <!-- Drop Zone -->
                <controls:DropZoneControl
                    DockPanel.Dock="Top"
                    Margin="12,12,12,8"
                    Height="140"
                    FilesSelected="DropZone_FilesSelected"/>

                <!-- Queue header -->
                <Grid DockPanel.Dock="Top" Margin="12,0,12,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center">
                        <Run Text="Files (" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="13"/>
                        <Run Text="{Binding QueueItems.Count, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="13"/>
                        <Run Text=")" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="13"/>
                    </TextBlock>
                    <Button Grid.Column="1"
                            Content="Clear All"
                            Style="{StaticResource LinkButton}"
                            Command="{Binding ClearQueueCommand}"
                            Visibility="{Binding IsProcessing, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                </Grid>

                <!-- Queue list -->
                <ListView ItemsSource="{Binding QueueItems}"
                          SelectedItem="{Binding SelectedQueueItem, Mode=TwoWay}"
                          BorderThickness="0"
                          Background="Transparent"
                          Margin="6,0,6,6"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="4,3"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:QueueItemViewModel}">
                            <Border CornerRadius="4" Padding="6,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- PDF icon -->
                                    <Viewbox Grid.Column="0" Width="16" Height="16" Margin="0,0,6,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Fill="{StaticResource ErrorBrush}"
                                                  Data="M20 2H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-8.5 7.5c0 .83-.67 1.5-1.5 1.5H9v2H7.5V7H10c.83 0 1.5.67 1.5 1.5v1zm5 2c0 .83-.67 1.5-1.5 1.5h-2.5V7H15c.83 0 1.5.67 1.5 1.5v3zm4-3H19v1h1.5V11H19v2h-1.5V7h3v1.5zM9 9.5h1v-1H9v1zM4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm10 5.5h1v-3h-1v3z"/>
                                        </Canvas>
                                    </Viewbox>

                                    <!-- File name -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding FileName, Mode=OneWay}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="12"
                                               ToolTip="{Binding FilePath, Mode=OneWay}"/>

                                    <!-- OCR badge -->
                                    <Border Grid.Column="2"
                                            Background="{StaticResource AccentBrush}"
                                            CornerRadius="3"
                                            Padding="3,1"
                                            Margin="4,0"
                                            Visibility="{Binding UsedOcr, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="OCR"
                                                   FontSize="9"
                                                   Foreground="White"
                                                   FontWeight="Bold"/>
                                    </Border>

                                    <!-- Status badge -->
                                    <Border Grid.Column="2"
                                            Style="{StaticResource StatusBadge}"
                                            Background="{Binding Status, Mode=OneWay, Converter={StaticResource StatusToColor}}"
                                            Margin="4,0"
                                            Visibility="{Binding UsedOcr, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                        <TextBlock Text="{Binding Status, Mode=OneWay, Converter={StaticResource StatusToString}}"
                                                   FontSize="10"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"/>
                                    </Border>

                                    <!-- Carrier badge -->
                                    <Border Grid.Column="3"
                                            CornerRadius="8"
                                            Padding="4,2"
                                            Margin="4,0"
                                            VerticalAlignment="Center"
                                            Background="{Binding DetectedCarrier, Mode=OneWay, Converter={StaticResource CarrierToBackground}}"
                                            Visibility="{Binding ShowCarrierBadge, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="{Binding CarrierBadgeText, Mode=OneWay}"
                                                   FontSize="9" FontWeight="Bold"
                                                   Foreground="{Binding DetectedCarrier, Mode=OneWay, Converter={StaticResource CarrierToForeground}}"/>
                                    </Border>

                                    <!-- Confidence -->
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding ConfidenceText, Mode=OneWay}"
                                               Foreground="{Binding ConfidenceColor, Mode=OneWay}"
                                               FontSize="10" FontWeight="Bold"
                                               Margin="4,0"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding IsCompleted, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                                    <!-- Duration -->
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding DurationText, Mode=OneWay}"
                                               FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="4,0"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding IsCompleted, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>

                                    <!-- Remove button -->
                                    <Button Grid.Column="5"
                                            Content="&#x2715;"
                                            FontSize="10"
                                            Background="Transparent"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Padding="4,2"
                                            Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>

            <!-- ── RIGHT COLUMN ── -->
            <DockPanel Grid.Column="1" Margin="0,12,12,12" LastChildFill="False">

                <!-- Action panel -->
                <Border DockPanel.Dock="Top"
                        Style="{StaticResource CardBorder}"
                        Padding="16"
                        Margin="0,0,0,12">
                    <StackPanel>

                        <!-- Output folder -->
                        <TextBlock Text="Output folder"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding SelectedOutputDirectory, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32" Padding="8,4"
                                     BorderBrush="{StaticResource SurfaceDarkBrush}"
                                     VerticalContentAlignment="Center"
                                     FontSize="12"/>
                            <Button Grid.Column="1"
                                    Content="Browse"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="8,0,0,0"
                                    Padding="10,6"
                                    Command="{Binding BrowseOutputDirectoryCommand}"/>
                        </Grid>

                        <Separator Background="{StaticResource SurfaceDarkBrush}" Margin="0,0,0,14"/>

                        <!-- Start button -->
                        <Button Height="44"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding StartProcessingCommand}">
                            <TextBlock FontSize="15" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text">
                                            <Setter.Value>
                                                <MultiBinding StringFormat="Process {0} Files">
                                                    <Binding Path="TotalFiles" Mode="OneWay"/>
                                                </MultiBinding>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsProcessing, Mode=OneWay}" Value="True">
                                                <Setter Property="Text" Value="Processing&#x2026;"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>

                        <!-- Progress bar -->
                        <ProgressBar Height="6"
                                     Margin="0,10,0,0"
                                     Value="{Binding ProgressPercent, Mode=OneWay}"
                                     Maximum="100"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="{StaticResource SurfaceDarkBrush}"
                                     Visibility="{Binding IsProcessing, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Status message -->
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   Margin="0,8,0,0"
                                   Visibility="{Binding HasStatusMessage, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Border>

                <!-- Result Preview Panel -->
                <Border DockPanel.Dock="Top"
                        Style="{StaticResource CardBorder}"
                        Padding="12"
                        Margin="0,0,0,12"
                        Visibility="{Binding SelectedQueueItem, Mode=OneWay, Converter={StaticResource NullToVisibility}}">
                    <StackPanel>
                        <TextBlock FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,8">
                            <Run Text="Preview: "/>
                            <Run Text="{Binding SelectedQueueItem.FileName, Mode=OneWay}"/>
                        </TextBlock>
                        <views:ResultPreviewPanel Result="{Binding SelectedResult, Mode=OneWay}"
                                                  MaxHeight="260"/>
                    </StackPanel>
                </Border>

                <!-- Export panel -->
                <Border DockPanel.Dock="Top"
                        Style="{StaticResource CardBorder}"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="Export Results"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,12"/>

                        <StackPanel Visibility="{Binding HasResults, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                            <UniformGrid Columns="2" Rows="1" Margin="0,0,0,10">
                                <Button Content="Export CSV"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,6,0"
                                        Command="{Binding ExportCsvCommand}"/>
                                <Button Content="Export Excel"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="6,0,0,0"
                                        Command="{Binding ExportExcelCommand}"/>
                            </UniformGrid>
                            <Button Content="Open Output Folder"
                                    Style="{StaticResource LinkButton}"
                                    HorizontalAlignment="Left"
                                    Command="{Binding OpenOutputFolderCommand}"/>
                        </StackPanel>

                        <TextBlock Text="Process files to enable export."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" FontStyle="Italic"
                                   Visibility="{Binding HasResults, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                    </StackPanel>
                </Border>

            </DockPanel>
        </Grid>

        <!-- ═══════════════════════════════════════
             ROW 3 — Status Bar
             ═══════════════════════════════════════ -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceDarkBrush}" Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: batch summary (visible after results) -->
                <TextBlock Grid.Column="0"
                           Text="{Binding BatchSummaryText, Mode=OneWay}"
                           VerticalAlignment="Center"
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                           Visibility="{Binding HasResults, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Right: provider pill + version pill -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Margin="0,0,5,0"
                             Fill="{StaticResource PrimaryLightBrush}"/>
                    <TextBlock Text="{Binding ActiveProviderText, Mode=OneWay}"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding Version, Mode=OneWay}"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
