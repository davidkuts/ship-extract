<Window x:Class="ShipExtract.UI.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ShipExtract.UI.Converters"
        Title="Batch History &#x2014; ShipExtract"
        Width="960" Height="580"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SurfaceBrush}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter         x:Key="BoolToVisibility"/>
        <converters:NullToVisibilityConverter         x:Key="NullToVisibility"/>
        <converters:ProcessingStatusToStringConverter x:Key="StatusToString"/>
        <converters:ProcessingStatusToColorConverter  x:Key="StatusToColor"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════
             ROW 0 — Header
             ═══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid Margin="16,0">
                <TextBlock Text="Batch History"
                           FontSize="16" FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="8,4"
                        Click="CloseButton_Click"
                        ToolTip="Close">
                    <TextBlock Text="&#x2715;" FontSize="14" Foreground="White"/>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════
             ROW 1 — Content (two-column layout)
             ═══════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="200"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT — Entry list -->
            <Border Grid.Column="0"
                    BorderBrush="{StaticResource SurfaceDarkBrush}"
                    BorderThickness="0,0,1,0"
                    Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Loading indicator -->
                    <TextBlock Grid.Row="0"
                               Text="Loading history..."
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Empty state -->
                    <TextBlock Grid.Row="0"
                               Text="No history entries"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsLoading, Mode=OneWay}" Value="False"/>
                                            <Condition Binding="{Binding HasEntries, Mode=OneWay}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Entry list -->
                    <ListBox Grid.Row="0"
                             ItemsSource="{Binding Entries, Mode=OneWay}"
                             SelectedItem="{Binding SelectedEntry}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding CompletedAtText, Mode=OneWay}"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding SummaryText, Mode=OneWay}"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Clear history button -->
                    <Button Grid.Row="1"
                            Content="Clear History"
                            Style="{StaticResource SecondaryButton}"
                            Margin="8"
                            Command="{Binding ClearHistoryCommand}"
                            Visibility="{Binding HasEntries, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource SurfaceDarkBrush}"/>

            <!-- RIGHT — Detail panel -->
            <Grid Grid.Column="2">

                <!-- No selection placeholder -->
                <TextBlock Text="Select a history entry to view details"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedEntry, Mode=OneWay}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Detail content -->
                <Grid Margin="16"
                      Visibility="{Binding SelectedEntry, Mode=OneWay, Converter={StaticResource NullToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Summary bar -->
                        <RowDefinition Height="Auto"/> <!-- Toolbar -->
                        <RowDefinition Height="*"/>    <!-- Results grid -->
                        <RowDefinition Height="Auto"/> <!-- Status message -->
                    </Grid.RowDefinitions>

                    <!-- Summary bar -->
                    <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="12" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Completed"
                                           FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding SelectedEntry.CompletedAtText, Mode=OneWay}"
                                           FontWeight="SemiBold" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Files"
                                           FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding SelectedEntry.TotalFiles, Mode=OneWay}"
                                           FontWeight="SemiBold" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Succeeded / Failed"
                                           FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding SelectedEntry.SuccessCount, Mode=OneWay}"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource SuccessBrush}"/>
                                    <TextBlock Text=" / " FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding SelectedEntry.FailureCount, Mode=OneWay}"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Primary Carrier"
                                           FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding SelectedEntry.CarrierText, Mode=OneWay}"
                                           FontWeight="SemiBold" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Load to Main Window"
                                Style="{StaticResource PrimaryButton}"
                                Padding="10,5"
                                Command="{Binding LoadBatchCommand}"/>
                        <Button Content="Export CSV"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,5"
                                Margin="6,0,0,0"
                                Command="{Binding ExportCsvCommand}"/>
                        <Button Content="Export Excel"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,5"
                                Margin="6,0,0,0"
                                Command="{Binding ExportExcelCommand}"/>
                        <Button Content="Delete Entry"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,5"
                                Margin="6,0,0,0"
                                Foreground="{StaticResource AccentBrush}"
                                Command="{Binding DeleteEntryCommand}"/>
                    </StackPanel>

                    <!-- Results DataGrid (populated by code-behind after loading detail) -->
                    <DataGrid x:Name="ResultsGrid"
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowBackground="White"
                              AlternatingRowBackground="#F8F8F8"
                              BorderThickness="1"
                              BorderBrush="{StaticResource SurfaceDarkBrush}"
                              FontSize="12"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="File"
                                                Binding="{Binding FileName}"
                                                Width="*"
                                                MinWidth="120"/>
                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding StatusText}"
                                                Width="90"/>
                            <DataGridTextColumn Header="Carrier"
                                                Binding="{Binding CarrierText}"
                                                Width="80"/>
                            <DataGridTextColumn Header="Tracking #"
                                                Binding="{Binding TrackingNumber}"
                                                Width="130"/>
                            <DataGridTextColumn Header="Shipper"
                                                Binding="{Binding ShipperName}"
                                                Width="130"/>
                            <DataGridTextColumn Header="Consignee"
                                                Binding="{Binding ConsigneeName}"
                                                Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Status message -->
                    <TextBlock Grid.Row="3"
                               Text="{Binding StatusMessage, Mode=OneWay}"
                               FontSize="11"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,4,0,0"
                               Visibility="{Binding HasStatusMessage, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════
             ROW 2 — Footer
             ═══════════════════════════════════════ -->
        <Border Grid.Row="2"
                BorderBrush="{StaticResource SurfaceDarkBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,8"
                Background="White">
            <Button Content="Close"
                    Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Right"
                    Width="80"
                    Click="CloseButton_Click"/>
        </Border>
    </Grid>
</Window>
