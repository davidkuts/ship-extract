<Window x:Class="ShipExtract.UI.Views.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ShipExtract.UI.Converters"
        Title="Welcome to ShipExtract"
        Width="520" Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="{StaticResource SurfaceBrush}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}" Height="80" Padding="20,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Welcome to ShipExtract"
                           FontSize="22" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Let&#x2019;s get you set up in a few steps"
                           FontSize="13" Foreground="White" Opacity="0.85" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Footer buttons -->
        <Border DockPanel.Dock="Bottom" Padding="16,12" BorderBrush="{StaticResource SurfaceDarkBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Button Content="Skip for now"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Left"
                        Padding="14,8"
                        Click="SkipButton_Click"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="ValidationText"
                               Text="Please enter your API key"
                               Foreground="{StaticResource ErrorBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Visibility="Collapsed"/>
                    <Button Content="Save &amp; Get Started"
                            Style="{StaticResource PrimaryButton}"
                            Padding="14,8"
                            Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Scrollable content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
            <StackPanel>

                <!-- Step 1: Provider Choice -->
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Step 1: Choose Your AI Provider"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" x:Name="OllamaProviderCard"
                                    BorderBrush="{StaticResource SuccessBrush}" BorderThickness="2"
                                    CornerRadius="6" Padding="10" Cursor="Hand"
                                    MouseLeftButtonUp="OllamaCard_Click" Background="White">
                                <StackPanel>
                                    <TextBlock Text="Ollama (Local)" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="Free · Private · No API key needed"
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" x:Name="AnthropicProviderCard"
                                    BorderBrush="{StaticResource SurfaceDarkBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="10" Cursor="Hand"
                                    MouseLeftButtonUp="AnthropicCard_Click" Background="White">
                                <StackPanel>
                                    <TextBlock Text="Anthropic Claude" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="Highest accuracy · Requires API key"
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Step 2A: API Key (only shown when Anthropic selected) -->
                <Border x:Name="ApiKeySection" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Step 2A: Anthropic API Key"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,10"
                                   Text="ShipExtract uses Claude AI to extract shipment data. You need an Anthropic API key to process documents."/>

                        <PasswordBox x:Name="ApiKeyBox"
                                     Height="34" Padding="8,6"
                                     FontSize="13"
                                     BorderBrush="{StaticResource SurfaceDarkBrush}"
                                     BorderThickness="1"/>

                        <Button Content="Get a free API key &#x2192;"
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"
                                Click="GetApiKey_Click"/>
                    </StackPanel>
                </Border>

                <!-- Step 2/3: Tessdata -->
                <Border Style="{StaticResource CardBorder}" Padding="16">
                    <StackPanel>
                        <TextBlock x:Name="TessStepLabel"
                                   Text="Step 2: OCR Support (Optional)"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,10"
                                   Text="To process scanned PDFs, download the Tesseract English language file and place it in the folder below."/>

                        <Button Content="Download eng.traineddata &#x2192;"
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,10"
                                Click="DownloadTessdata_Click"/>

                        <TextBlock Text="Save it to:" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="TessPathBox"
                                 IsReadOnly="True"
                                 Height="30" Padding="8,4"
                                 FontSize="11"
                                 BorderBrush="{StaticResource SurfaceDarkBrush}"
                                 Background="{StaticResource SurfaceBrush}"
                                 Margin="0,0,0,8"/>

                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="TessStatusIcon" Text="&#x25CF;" FontSize="10"
                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TessStatusText" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Content="Check Again"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Right"
                                    Padding="10,4"
                                    Click="CheckTessdata_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
