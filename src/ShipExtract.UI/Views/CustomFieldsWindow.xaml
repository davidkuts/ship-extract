<Window x:Class="ShipExtract.UI.Views.CustomFieldsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ShipExtract.UI.Converters"
        Title="Custom Fields &#x2014; ShipExtract"
        Width="640" Height="560"
        MinWidth="560" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SurfaceBrush}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <DockPanel Margin="20">

        <!-- Buttons row pinned to bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Vertical" HorizontalAlignment="Right" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="SaveButton" Content="Save"
                        Style="{StaticResource PrimaryButton}"
                        Width="90" Click="SaveButton_Click"/>
                <Button Content="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Width="90" Margin="8,0,0,0"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </StackPanel>

        <StackPanel>

            <!-- Title row -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Custom Fields"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,2,0,0" TextWrapping="Wrap">
                        Add extra fields for the AI to extract. Each enabled field is added to every AI prompt and exported as an extra column.
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="12,0,0,0">
                    <Button x:Name="AddButton" Content="+ Add Field"
                            Style="{StaticResource SecondaryButton}"
                            Padding="10,5"
                            Click="AddField_Click"/>
                </StackPanel>
            </Grid>

            <!-- Built-in examples hint -->
            <Border Background="{StaticResource SurfaceDarkBrush}" CornerRadius="4"
                    Padding="10,8" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Quick examples — click to add:"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="PO Number" Style="{StaticResource LinkButton}" FontSize="11"
                                Tag="PO Number" Click="ExampleField_Click" Margin="0,0,8,0"/>
                        <Button Content="Invoice Number" Style="{StaticResource LinkButton}" FontSize="11"
                                Tag="Invoice Number" Click="ExampleField_Click" Margin="0,0,8,0"/>
                        <Button Content="Incoterms" Style="{StaticResource LinkButton}" FontSize="11"
                                Tag="Incoterms" Click="ExampleField_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- DataGrid of custom fields -->
            <DataGrid x:Name="FieldsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="{StaticResource SurfaceDarkBrush}"
                      RowBackground="White"
                      AlternatingRowBackground="{StaticResource SurfaceBrush}"
                      HeadersVisibility="Column"
                      Height="260"
                      Margin="0,0,0,8">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="On" Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}" Width="38"/>
                    <DataGridTextColumn Header="Field Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                    <DataGridTextColumn Header="Extraction Hint" Binding="{Binding ExtractionHint, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                    <DataGridTextColumn Header="Default" Binding="{Binding DefaultValue, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                    <DataGridTemplateColumn Header="" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Delete"
                                        Style="{StaticResource LinkButton}"
                                        FontSize="11"
                                        Foreground="{StaticResource ErrorBrush}"
                                        Tag="{Binding}"
                                        Click="DeleteField_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Warning for many fields -->
            <TextBlock x:Name="ManyFieldsWarning"
                       Text="&#x26A0; More than 10 custom fields may reduce AI accuracy."
                       FontSize="11" Foreground="{StaticResource WarningBrush}"
                       Visibility="Collapsed" Margin="0,0,0,4"/>

            <!-- Prompt preview -->
            <Expander Header="Preview AI prompt addition" IsExpanded="False" Margin="0,4,0,0">
                <TextBox x:Name="PromptPreview"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="10"
                         Background="{StaticResource SurfaceDarkBrush}"
                         BorderThickness="0"
                         Padding="8"
                         MaxHeight="120"
                         VerticalScrollBarVisibility="Auto"/>
            </Expander>

        </StackPanel>
    </DockPanel>
</Window>
